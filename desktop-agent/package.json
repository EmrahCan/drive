{
  "name": "lexora-desktop-agent",
  "version": "0.1.0",
  "description": "Lexora Masaüstü Ajanı — seçilen klasörlerdeki hukuki belgeleri otomatik olarak Lexora'ya yükler.",
  "main": "main.cjs",
  "author": "Lexora",
  "repository": {
    "type": "git",
    "url": "https://github.com/EmrahCan/drive.git"
  },
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win",
    "dist:linux": "electron-builder --linux"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "chokidar": "^3.6.0",
    "electron-store": "^8.2.0",
    "form-data": "^4.0.0",
    "node-fetch": "^2.7.0"
  },
  "devDependencies": {
    "@electron/packager": "^20.0.2",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "app.lexora.agent",
    "productName": "Lexora Agent",
    "copyright": "Copyright © 2026 Lexora",
    "asar": true,
    "files": ["main.cjs","preload.cjs","renderer.html","build/**/*"],
    "directories": {"buildResources": "build","output": "release"},
    "publish": [{"provider":"github","owner":"EmrahCan","repo":"drive"}],
    "mac": {
      "target": [{"target":"dmg","arch":["universal"]},{"target":"zip","arch":["universal"]}],
      "category": "public.app-category.productivity",
      "icon": "build/icon.png",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "identity": null
    },
    "dmg": {"title": "Lexora Agent","writeUpdateInfo": false},
    "win": {
      "target": [{"target":"nsis","arch":["x64"]},{"target":"portable","arch":["x64"]}],
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Lexora Agent"
    },
    "linux": {
      "target": ["AppImage","deb"],
      "category": "Office",
      "icon": "build/icon.png"
    }
  }
}
